# Required for scans and approval delivery. /health starts without these values.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hiltech_zoho_bot?schema=public"
OPENAI_API_KEY="your-openai-api-key"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_APPROVER_CHAT_ID="123456789"
SCAN_SECRET="use-a-long-random-secret"

# Runtime
PORT=3000
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
APP_BASE_URL="https://your-app.up.railway.app"
# Generate a long random value and use the same value when registering the Telegram webhook.
TELEGRAM_WEBHOOK_SECRET="generate-a-long-random-secret"
ENABLE_LOCAL_SCHEDULER=false
CRON_SCHEDULE="0 8,20 * * *"

# Kept disabled for future Facebook Page integration.
FACEBOOK_PAGE_PUBLISHING_ENABLED=false
FACEBOOK_PAGE_ACCESS_TOKEN=""
FACEBOOK_PAGE_ID=""
